<?xml version="1.0"?>
<robot name="chris_robot">

  <material name="red"><color rgba="1.0 0.0 0.0 1.0"/></material>
  <material name="white"><color rgba="1.0 1.0 1.0 1.0"/></material>
  <material name="yellow"><color rgba="1.0 1.0 0.0 1.0"/></material>

  <link name="base_link">
    <visual>
      <geometry><cylinder length="0.6" radius="0.2"/></geometry>
      <material name="red"/>
    </visual>
  </link>

  <joint name="arm_0_joint" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.3" rpy="0 0 0"/>
    <axis xyz="0 0 1"/> <limit lower="-3.14" upper="3.14" effort="10.0" velocity="1.0"/>
  </joint>

  <link name="link1">
    <visual>
      <geometry><cylinder length="0.6" radius="0.1"/></geometry>
      <origin xyz="0 0 0.3" rpy="0 0 0"/>
      <material name="white"/>
    </visual>
  </link>

  <joint name="arm_1_joint" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0.6" rpy="0 0 0"/>
    <axis xyz="0 1 0"/> <limit lower="-1.57" upper="1.57" effort="10.0" velocity="1.0"/>
  </joint>

  <link name="link2">
    <visual>
      <geometry><cylinder length="0.6" radius="0.1"/></geometry>
      <origin xyz="0 0 0.3" rpy="0 0 0"/>
      <material name="red"/>
    </visual>
  </link>

  <joint name="arm_2_joint" type="revolute">
    <parent link="link2"/>
    <child link="hand_link"/>
    <origin xyz="0 0 0.6" rpy="0 0 0"/>
    <axis xyz="0 1 0"/> <limit lower="-1.57" upper="1.57" effort="10.0" velocity="1.0"/>
  </joint>

  <link name="hand_link">
    <visual>
      <geometry><box size="0.2 0.2 0.1"/></geometry>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <material name="white"/>
    </visual>
  </link>

  <joint name="gripper_l_joint" type="prismatic">
    <parent link="hand_link"/>
    <child link="gripper_l_finger"/>
    <origin xyz="-0.05 0 0.1" rpy="0 0 0"/>
    <axis xyz="1 0 0"/> <limit lower="-0.05" upper="0.0" effort="10.0" velocity="1.0"/>
  </joint>

  <link name="gripper_l_finger">
    <visual>
      <geometry><box size="0.03 0.05 0.1"/></geometry>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <material name="yellow"/>
    </visual>
  </link>

  <joint name="gripper_r_joint" type="prismatic">
    <parent link="hand_link"/>
    <child link="gripper_r_finger"/>
    <origin xyz="0.05 0 0.1" rpy="0 0 0"/>
    <axis xyz="1 0 0"/> <limit lower="0.0" upper="0.05" effort="10.0" velocity="1.0"/>
  </joint>

  <link name="gripper_r_finger">
    <visual>
      <geometry><box size="0.03 0.05 0.1"/></geometry>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <material name="yellow"/>
    </visual>
  </link>

</robot>